#!/usr/bin/env bash
set -euo pipefail

POLL=${KIRO_SIDEBAR_POLL:-2}
KIRO_DB="$HOME/Library/Application Support/kiro-cli/data.sqlite3"
KIRO_TODOS="$HOME/Library/Application Support/kiro-cli/todo-lists"
CWD=${KIRO_SIDEBAR_CWD:-$(pwd)}

R="\033[0m"; DIM="\033[2m"; BOLD="\033[1m"
CYAN="\033[36m"; GREEN="\033[32m"; RED="\033[31m"
YELLOW="\033[33m"; MAGENTA="\033[35m"; WHITE="\033[97m"; BLUE="\033[34m"

find_todo() {
  local todo_file=""
  todo_file=$(python3 -c "
import json, glob, os, sys, sqlite3

base, cwd, db_path = sys.argv[1], sys.argv[2], sys.argv[3]

def latest_snap(d):
    files = sorted(glob.glob(f'{d}/*.json'))
    return files[-1] if files else None

# Strategy 1: match session_id to conversation_id
try:
    conn = sqlite3.connect(db_path)
    row = conn.execute(
        'SELECT conversation_id, created_at FROM conversations_v2 WHERE key=? ORDER BY updated_at DESC LIMIT 1',
        (cwd,)).fetchone()
    conn.close()
    if row:
        conv_id, conv_created = row
        for d in glob.glob(f'{base}/*'):
            f = latest_snap(d)
            if f and json.load(open(f)).get('session_id') == conv_id:
                print(f); sys.exit()

        # Strategy 2: match by modified_files under cwd (check all snapshots)
        best, best_mt = '', 0
        for d in glob.glob(f'{base}/*'):
            files = sorted(glob.glob(f'{d}/*.json'))
            if not files: continue
            matched = False
            for f in files:
                data = json.load(open(f))
                if any(mf.startswith(cwd) for mf in data.get('modified_files', [])):
                    matched = True; break
            if matched:
                mt = os.path.getmtime(files[-1])
                if mt > best_mt: best, best_mt = files[-1], mt
        if best:
            print(best); sys.exit()

        # Strategy 3: newest todo created after conversation started
        # (handles freshly-created todos with no modified_files yet)
        conv_ts = conv_created / 1000.0
        best, best_mt = '', 0
        for d in glob.glob(f'{base}/*'):
            files = sorted(glob.glob(f'{d}/*.json'))
            if not files: continue
            first = files[0]
            # filename is creation timestamp in ms
            try:
                create_ts = int(os.path.basename(first).replace('.json','')) / 1000.0
            except ValueError:
                continue
            if create_ts >= conv_ts:
                mt = os.path.getmtime(files[-1])
                if mt > best_mt: best, best_mt = files[-1], mt
        if best:
            print(best)
except Exception:
    pass
" "$KIRO_TODOS" "$CWD" "$KIRO_DB" 2>/dev/null)
  echo "$todo_file"
}

fingerprint() {
  local fp=""
  # todo dir mtime (catches new/updated snapshots)
  local todo_file
  todo_file=$(find_todo)
  if [[ -n "$todo_file" ]]; then
    fp+=$(stat -f "%m" "$todo_file" 2>/dev/null)
    fp+=":$(stat -f "%m" "$(dirname "$todo_file")" 2>/dev/null)"
  fi
  # watch base todo dir + all subdirs for new todo lists/snapshots
  fp+=":$(stat -f "%m" "$KIRO_TODOS" 2>/dev/null)"
  for d in "$KIRO_TODOS"/*/; do
    fp+=":$(stat -f "%m" "$d" 2>/dev/null)"
  done
  fp+="|"
  # git index + worktree
  if git -C "$CWD" rev-parse --is-inside-work-tree &>/dev/null; then
    local git_dir
    git_dir=$(git -C "$CWD" rev-parse --git-dir 2>/dev/null)
    fp+=$(stat -f "%m" "$git_dir/index" 2>/dev/null)
    fp+=":$(git -C "$CWD" status --porcelain 2>/dev/null | md5 -q)"
  fi
  echo "$fp"
}

draw() {
  local cols=$(tput cols)
  clear
  echo ""
  printf "${CYAN}${BOLD}"
  cat <<'EOF'
  ██╗  ██╗██╗██████╗  ██████╗
  ██║ ██╔╝██║██╔══██╗██╔═══██╗
  █████╔╝ ██║██████╔╝██║   ██║
  ██╔═██╗ ██║██╔══██╗██║   ██║
  ██║  ██╗██║██║  ██║╚██████╔╝
  ╚═╝  ╚═╝╚═╝╚═╝  ╚═╝ ╚═════╝
EOF
  printf "${R}"
  printf "  ${DIM}sidebar dashboard${R}\n\n"

  sep() { printf "${DIM}"; printf '─%.0s' $(seq 1 "$cols"); printf "${R}\n"; }

  printf "  ${MAGENTA}${BOLD}📋 TODO${R}\n"
  sep
  local todo_file
  todo_file=$(find_todo)
  if [[ -n "$todo_file" && -f "$todo_file" ]]; then
    python3 -c "
import json, sys
data = json.load(open(sys.argv[1]))
print(f'  \033[2m{data[\"description\"]}\033[0m')
for t in data.get('tasks', []):
    d = t['task_description']
    if t.get('completed'):
        print(f'  \033[32m  ✓ \033[2m{d}\033[0m')
    else:
        print(f'  \033[33m  ○ {d}\033[0m')
" "$todo_file"
  else
    printf "  ${DIM}no todo list found for this project${R}\n"
  fi
  echo ""

  printf "  ${BLUE}${BOLD}  GIT STATUS${R}\n"
  sep
  if git -C "$CWD" rev-parse --is-inside-work-tree &>/dev/null; then
    local branch
    branch=$(git -C "$CWD" branch --show-current 2>/dev/null || echo "detached")
    printf "  ${DIM}branch:${R} ${CYAN}${branch}${R}\n"
    local staged unstaged untracked
    staged=$(git -C "$CWD" diff --cached --name-status 2>/dev/null)
    unstaged=$(git -C "$CWD" diff --name-status 2>/dev/null)
    untracked=$(git -C "$CWD" ls-files --others --exclude-standard 2>/dev/null)
    if [[ -n "$staged" ]]; then
      printf "\n  ${GREEN}${BOLD}Staged${R}\n"
      while IFS=$'\t' read -r status file; do
        printf "  ${GREEN}  %-2s %s${R}\n" "$status" "$file"
      done <<< "$staged"
    fi
    if [[ -n "$unstaged" ]]; then
      printf "\n  ${RED}${BOLD}Modified${R}\n"
      while IFS=$'\t' read -r status file; do
        printf "  ${RED}  %-2s %s${R}\n" "$status" "$file"
      done <<< "$unstaged"
    fi
    if [[ -n "$untracked" ]]; then
      printf "\n  ${DIM}${BOLD}Untracked${R}\n"
      while read -r file; do
        printf "  ${DIM}  ?  %s${R}\n" "$file"
      done <<< "$untracked"
    fi
    if [[ -z "$staged" && -z "$unstaged" && -z "$untracked" ]]; then
      printf "  ${GREEN}  ✓ working tree clean${R}\n"
    fi
  else
    printf "  ${DIM}not a git repo${R}\n"
  fi
  echo ""
  sep
  printf "  ${DIM}watching for changes (poll ${POLL}s)${R}\n"
}

# Initial draw
last_fp=""
while true; do
  fp=$(fingerprint)
  if [[ "$fp" != "$last_fp" ]]; then
    draw
    last_fp="$fp"
  fi
  sleep "$POLL"
done
