#!/usr/bin/env bash
set -euo pipefail

if [[ -n "${TMUX:-}" ]]; then
  tmux split-window -h -l 60 "KIRO_SIDEBAR_CWD='$(pwd)' $HOME/dev-env/.local/scripts/kiro-sidebar"
  tmux select-pane -L
fi

kiro-cli chat "$@"

# kill sidebar when kiro exits
pane=$(tmux list-panes -F "#{pane_id}:#{pane_pid}" 2>/dev/null | while IFS=: read -r id pid; do
  ps -p "$pid" -o args= 2>/dev/null | grep -q kiro-sidebar && echo "$id" && break
done)
[[ -n "${pane:-}" ]] && tmux kill-pane -t "$pane" 2>/dev/null
exit 0
